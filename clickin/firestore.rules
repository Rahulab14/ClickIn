rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the current user is an Admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Grant FULL access to all database collections for Admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Users Collection
    match /users/{uid} {
      // Users can read/write their own profile, Admins can read/write everything
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      
      // Allow customers to read, update (mark as read), and delete their notifications
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
    }

    // 2. Vendors Collection - Business profiles
    match /vendors/{uid} {
      // Allow creation during signup if UID matches
      // Allow read/update if UID matches or Admin
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read, update, delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }
    
    // 3. Staff Collection - Employee profiles
    match /staff/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      
      // Allow read if querying by shopId the user owns, OR if Admin, OR if reading own profile
      allow read: if request.auth != null && (
        request.auth.uid == uid || 
        isAdmin() || 
        (
          resource != null && 
          resource.data.shopId != null && 
          get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid
        )
      );
      
      allow update, delete: if request.auth != null && (
        request.auth.uid == uid || 
        isAdmin() || 
        (
          resource != null && 
          resource.data.shopId != null && 
          get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid
        )
      );
    }
    
    // 4. Shops Collection - allowing vendor owners to create shops
    match /shops/{shopId} {
      // Temporarily allow authenticated users to create shops during signup
      allow create: if request.auth != null;
      allow read: if true; // Public can read shops
      
      // Allow vendor owner/admin to update everything. 
      // Allow customers to update ONLY the rating fields for the real-time average calculation.
      allow update: if (request.auth != null && (isAdmin() || resource.data.ownerId == request.auth.uid)) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingCount', 'totalStars', 'updatedAt']));
                       
      allow delete: if request.auth != null && (isAdmin() || resource.data.ownerId == request.auth.uid);
      
      // Specific rule for menu items
      match /menu/{itemId} {
        allow read: if true;
        allow update: if request.auth != null && (
          (exists(/databases/$(database)/documents/shops/$(shopId)) && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid) || 
          isAdmin() ||
          // If staff, only allow stock/availability updates
          (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.shopId == shopId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'available', 'updatedAt']))
        );
        allow create, delete: if request.auth != null && (
          isAdmin() || 
          (exists(/databases/$(database)/documents/shops/$(shopId)) && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid) ||
          (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.shopId == shopId)
        );
      }
      
      // Staff subcollection inside a shop
      match /staff/{staffDocId} {
        allow read, write, delete: if request.auth != null && isAdmin();
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
      }

      // Settings
      match /config/settings {
        allow read: if true;
        allow write: if request.auth != null && (
          (exists(/databases/$(database)/documents/shops/$(shopId)) && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid) || 
          isAdmin()
        );
      }
      
      // Notifications
      match /notifications/{docId} {
        allow create: if request.auth != null;
        allow read, update, delete: if request.auth != null && (
          (exists(/databases/$(database)/documents/shops/$(shopId)) && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid) || 
          isAdmin() ||
          (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.shopId == shopId)
        );
      }

      // Subcollections (orders history, dailySummary, staffActivity, transactions, etc.)
      match /{subcol}/{subDocId} {
        allow read, write: if request.auth != null && (
          (exists(/databases/$(database)/documents/shops/$(shopId)) && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid) || 
          isAdmin() ||
          (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.shopId == shopId)
        );
        allow delete: if request.auth != null && (
          (exists(/databases/$(database)/documents/shops/$(shopId)) && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid) || 
          isAdmin()
        );
      }
    }

    // 5. Transactions Collection (Root level)
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null && (
        isAdmin() ||
        (resource != null && resource.data.shopId != null && exists(/databases/$(database)/documents/shops/$(resource.data.shopId)) && get(/databases/$(database)/documents/shops/$(resource.data.shopId)).data.ownerId == request.auth.uid) ||
        (request.resource != null && request.resource.data.shopId != null && exists(/databases/$(database)/documents/shops/$(request.resource.data.shopId)) && get(/databases/$(database)/documents/shops/$(request.resource.data.shopId)).data.ownerId == request.auth.uid)
      );
    }

    // 5. Orders Collection
    match /orders/{orderId} {
      allow create: if true; // Any customer can place an order
      allow read: if true; // In MVP we might just want to let customers see their orders
      
      // Allow vendors to update everything, but also allow customers (even guests) to update 'isRated' status and 'cancelReason'/'status' if needed.
      allow update: if true; 
      allow delete: if request.auth != null; // Vendor logic handles delete
    }

    // 6. Ratings Collection
    match /ratings/{ratingId} {
      allow create: if true; // Any customer can leave a rating
      allow read: if true;
    }

    // 7. Feedback Collection
    match /feedback/{feedbackId} {
      allow create: if request.auth != null; // Authenticated users can submit feedback
      allow read: if request.auth != null; // Allow authenticated users (like admin testers) to read
      allow update, delete: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
